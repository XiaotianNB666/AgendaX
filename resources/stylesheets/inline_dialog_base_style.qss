#inlineDialog {
    background-color: white;
    border: 1px solid #ccc;
    border-radius: 5px;
}

#titleBar {
    background-color: #f0f0f0;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
}

#titleLabel {
    font-weight: bold;
    color: #333;
}

#closeBtn {
    background-color: transparent;
    border: none;
    color: #999;
    font-size: 16px;
    font-weight: bold;
}

#closeBtn:hover {
    color: #333;
}